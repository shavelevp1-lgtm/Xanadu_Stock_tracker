# Copy to .env for local testing only. Do not commit .env.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your-app-password-here
EMAIL_TO=your.email@gmail.com
EMAIL_FROM=your.email@gmail.com
# Optional: overrides the auto-generated subject (NASDAQ % change is included by default)
# EMAIL_SUBJECT=Custom subject line

# CEO filing monitor (monitor_ceo_filings.py) — required by SEC fair-access policy
SEC_USER_AGENT=XNDU-Monitor your.email@example.com

# Monitor tuning (optional; used by daily email insider section)
# VOLUME_SPIKE_RATIO=2.0
# VOLUME_AVG_DAYS=20
# VOLUME_SCAN_DAYS=5
# LARGE_SALE_MIN_SHARES=100000

